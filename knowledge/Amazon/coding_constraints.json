{
  "company": "Amazon",
  "version": "1.0",

  "supported_languages": [
    "Java",
    "C++",
    "Python",
    "C",
    "JavaScript"
  ],

  "preferred_languages": [
    "Java",
    "C++",
    "Python"
  ],

  "minimum_coding_questions": 2,
  "maximum_coding_questions": 3,

  "difficulty_distribution": {
    "Easy": 15,
    "Medium": 55,
    "Hard": 30
  },

