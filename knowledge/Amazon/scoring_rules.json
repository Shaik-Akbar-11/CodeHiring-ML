    "time_complexity": 20,
    "space_complexity": 10,
    "edge_case_handling": 10,
    "code_quality": 5,
    "readability": 5
  },

  "mcq_evaluation": {
    "correct_answer": 100,
    "partial_marks": false,
    "negative_marking": false
  },

  "behavioral_evaluation": {
    "leadership_principles": 40,
    "problem_solving": 20,
    "communication": 15,
    "ownership": 15,
    "customer_obsession": 10
